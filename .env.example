# ============================================================
# 云南省企业数据采集系统 - 环境变量
# 用法：复制本文件为项目根目录下的 .env（无 .example 后缀），再填写你的 Supabase 项目里的真实值。
# ============================================================

# ── Supabase（必填：后端登录、npm run db:seed 都依赖这两项）────────────────
# 打开 Supabase 控制台 → 你的项目 → Settings → API
#   SUPABASE_URL        = Project URL（形如 https://xxxx.supabase.co）
#   SUPABASE_SERVICE_ROLE_KEY = service_role 密钥（务必保密，勿提交到 Git）
# 注意：seed 写入的用户必须在「同一个」Supabase 项目里；改 .env 后请重启 npm run dev
SUPABASE_URL=https://你的项目.supabase.co
SUPABASE_SERVICE_ROLE_KEY=你的_service_role_密钥

# 可选：若前端直连 Supabase 客户端时使用
SUPABASE_ANON_KEY=你的_anon_公钥

# ── 后端 ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# 浏览器访问前端的地址（CORS），本地一般为：
APP_URL=http://localhost:3000

# ── 前端（Vite 会读取 VITE_ 开头的变量）────────────────────────
# 必须与后端 API 一致，否则登录请求会发到错误地址
VITE_API_URL=http://localhost:3001/api

# 可选：与 SUPABASE_* 一致，供前端 Supabase 客户端使用
# VITE_SUPABASE_URL=https://你的项目.supabase.co
# VITE_SUPABASE_ANON_KEY=你的_anon_公钥

# 可选：npm run db:seed 时演示账号密码，不设则默认为 Demo123456
# SEED_DEMO_PASSWORD=Demo123456
